{
  "name": "Clipboard History",
  "id": "clipboard-history",
  "version": "1.0.0",
  "description": "Manage and access your clipboard history",
  "type": "extension",
  "searchable": true,
  "icon": "icon:clipboard",
  "actions": [
    {
      "id": "clear-history",
      "title": "Clear Clipboard History",
      "description": "Remove all non-favorite clipboard items",
      "icon": "icon:trash",
      "category": "System"
    }
  ],
  "commands": [
    {
      "id": "show-clipboard",
      "name": "Show Clipboard History",
      "description": "Show clipboard history",
      "trigger": "clip",
      "icon": "icon:clipboard",
      "mode": "view",
      "component": "DefaultView",
      "searchBarAccessory": {
        "type": "dropdown",
        "default": "all",
        "options": [
          { "value": "all",    "title": "All Types" },
          { "value": "text",   "title": "Text" },
          { "value": "images", "title": "Images" },
          { "value": "files",  "title": "Files" }
        ]
      }
    }
  ]
}
