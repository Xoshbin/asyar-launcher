// ──────────────────────────────────────────────────────────────────────
// index.ts — Extension class for a logic/no-view extension.
//
// This extension contributes actions through search() results. When the
// user selects one, the action's `execute` closure runs directly inside
// the iframe without mounting any view.
//
// Bootstrap flow:
//   1. main.ts imports this class and calls extension.initialize(context)
//      which captures a reference to ExtensionContext for later reads.
//   2. main.ts registers the class with ExtensionBridge so the bridge
//      can dispatch asyar:search:request messages into search().
//   3. The host invokes search() as the user types in the global search
//      bar. search() returns ExtensionResult[] with per-item action
//      closures.
//   4. When the user selects a result, the host posts an
//      asyar:action:execute message back to the iframe. The bridge
//      routes it to the registered action by ID (handled internally —
//      you just return the closure in search()).
// ──────────────────────────────────────────────────────────────────────

import type {
  Extension,
  ExtensionContext,
  ExtensionResult,
  ILogService,
  INotificationService,
} from "asyar-sdk";

// Sample actions — replace with your own logic
const SAMPLE_ACTIONS = [
  { id: "action-1", title: "First Action", subtitle: "Does the first thing" },
  { id: "action-2", title: "Second Action", subtitle: "Does the second thing" },
];

class MyExtension implements Extension {
  private context?: ExtensionContext;
  private logger?: ILogService;
  private notifications?: INotificationService;

  async initialize(context: ExtensionContext): Promise<void> {
    this.context = context;
    this.logger = context.getService<ILogService>("LogService");
    this.notifications = context.getService<INotificationService>("NotificationService");
  }

  async activate(): Promise<void> {}
  async deactivate(): Promise<void> {}
  async viewActivated(_viewId: string): Promise<void> {}
  async viewDeactivated(_viewId: string): Promise<void> {}

  async search(query: string): Promise<ExtensionResult[]> {
    const q = query.toLowerCase();
    return SAMPLE_ACTIONS
      .filter((item) => !q || item.title.toLowerCase().includes(q))
      .map((item) => ({
        score: 1,
        title: item.title,
        subtitle: item.subtitle,
        type: "result" as const,
        action: async () => {
          this.logger?.info(`{{EXTENSION_NAME}}: running action "${item.id}"`);
          // TODO: implement your action logic here

          // Read the `notifyOnComplete` preference live on every call —
          // the user may have toggled it since the last action ran.
          const shouldNotify = Boolean(this.context?.preferences.notifyOnComplete);
          if (shouldNotify) {
            await this.notifications?.notify({
              title: "{{EXTENSION_NAME}}",
              body: `Ran: ${item.title}`,
            });
          }
        },
      }));
  }

  async executeCommand(commandId: string, _args?: Record<string, any>): Promise<any> {
    if (commandId === "run") {
      this.logger?.info("{{EXTENSION_NAME}}: run command triggered");
    }
  }

  onUnload = () => {};
}

export default new MyExtension();
