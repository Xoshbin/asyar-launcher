<script lang="ts">
  import type { ILogService } from 'asyar-sdk';

  interface Props {
    logger: ILogService;
  }
  let { logger }: Props = $props();

  let count = $state(0);

  function handleClick() {
    count++;
    logger.info(`{{EXTENSION_NAME}}: button clicked ${count} times`);
  }
</script>

<div class="p-6 h-full flex flex-col items-center justify-center bg-[var(--bg-primary)] text-[var(--text-primary)]">
  <h1 class="text-2xl font-bold mb-4">Hello from {{EXTENSION_NAME}}!</h1>
  <p class="mb-6" style="color: var(--text-secondary)">This is your new sandboxed extension view.</p>

  <button onclick={handleClick} class="btn-primary">
    Clicked {count} times
  </button>
</div>

