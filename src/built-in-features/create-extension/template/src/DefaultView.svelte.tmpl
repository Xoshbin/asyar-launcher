<script lang="ts">
  import type { ILogService } from 'asyar-sdk';

  interface Props {
    logger: ILogService;
  }
  let { logger }: Props = $props();

  let count = $state(0);

  function handleClick() {
    count++;
    logger.info(`{{EXTENSION_NAME}}: button clicked ${count} times`);
  }
</script>

<div class="container">
  <div class="header">
    <asyar-icon name="rocket" size="32" stroke-width="2"></asyar-icon>
    <h1>Hello from {{EXTENSION_NAME}}!</h1>
  </div>
  
  <p class="description">This is your new sandboxed extension view.</p>

  <button onclick={handleClick} class="btn-primary">
    <asyar-icon name="plus" size="16"></asyar-icon>
    Clicked {count} times
  </button>
</div>

