import { mount } from 'svelte';
import DetailView from './DetailView.svelte';
import { ExtensionContext, type ILogService } from 'asyar-sdk';

const extensionId = window.location.hostname || '{{EXTENSION_ID}}';

// 1. Initialize SDK context — single instance for the entire extension lifetime
const context = new ExtensionContext();
context.setExtensionId(extensionId);

// 2. Notify host that we are loaded and ready
window.parent.postMessage({ type: 'asyar:extension:loaded', extensionId }, '*');

// 3. Forward Cmd+K (and other global shortcuts) to the host
window.addEventListener('keydown', (event) => {
  const isCommandK = (event.metaKey || event.ctrlKey) && event.key === 'k';
  if (isCommandK) {
    event.preventDefault();
    window.parent.postMessage({
      type: 'asyar:extension:keydown',
      payload: {
        key: event.key,
        metaKey: event.metaKey,
        ctrlKey: event.ctrlKey,
        shiftKey: event.shiftKey,
        altKey: event.altKey,
      }
    }, '*');
  }
});

// 4. Mount the detail view, passing services from the single context as props
const app = mount(DetailView, {
  target: document.getElementById('app')!,
  props: {
    logger: context.getService<ILogService>('LogService'),
  }
});

export default app;
