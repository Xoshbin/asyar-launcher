// ───────────────────────────────────────────────────────────────────────────
// main.ts — Tier 2 extension bootstrap (result/searchable variant)
//
// This is the bootstrap for a Tier 2 extension that:
//   - Declares `searchable: true` in manifest.json
//   - Contributes results to the global launcher search via
//     `extension.search(query)` in index.ts
//   - Also mounts a detail view when the user activates a result
//
// The registration step below is what wires the search method into the
// iframe's ExtensionBridge. Without it, the bridge has nothing to hand
// `asyar:search:request` messages to and your search() method is never
// called.
//
// Bootstrap order:
//   1. Parse extensionId from the asyar-extension://{id}/ URL
//   2. Create ExtensionContext + setExtensionId (self-registers with the
//      bridge so preferences bundles land on this live context)
//   3. Register manifest + extension implementation with the bridge
//   4. Forward Cmd+K to the host
//   5. Post asyar:extension:loaded — host replies with initial prefs
//   6. Mount the detail view with `context` as a prop
// ───────────────────────────────────────────────────────────────────────────

import 'asyar-sdk/tokens.css';
import { mount } from 'svelte';
import {
  extensionBridge,
  ExtensionContext,
  registerIconElement,
  type ILogService,
} from 'asyar-sdk';
import extension, { DetailView } from './index';
import manifest from '../manifest.json';

const extensionId = (
  window.location.hostname === 'localhost' ||
  window.location.hostname === 'asyar-extension.localhost'
)
  ? window.location.pathname.split('/').filter(Boolean)[0] || '{{EXTENSION_ID}}'
  : window.location.hostname || '{{EXTENSION_ID}}';

// 1. Single ExtensionContext for the whole iframe lifetime.
const context = new ExtensionContext();
context.setExtensionId(extensionId);
registerIconElement();

// 2. Register with ExtensionBridge so it can dispatch:
//      - asyar:search:request → extension.search(query)
//      - asyar:command:execute → extension.executeCommand(commandId, args)
//    This is required for searchable extensions. The bridge's message
//    listener looks up the registered implementation by extensionId and
//    calls the appropriate method.
extensionBridge.registerManifest(manifest as any);
extensionBridge.registerExtensionImplementation(extensionId, extension);

// 3. Forward Cmd+K (and other global shortcuts) to the host.
window.addEventListener('keydown', (event) => {
  const isCommandK = (event.metaKey || event.ctrlKey) && event.key === 'k';
  if (isCommandK) {
    event.preventDefault();
    window.parent.postMessage({
      type: 'asyar:extension:keydown',
      payload: {
        key: event.key,
        metaKey: event.metaKey,
        ctrlKey: event.ctrlKey,
        shiftKey: event.shiftKey,
        altKey: event.altKey,
      },
    }, '*');
  }
});

// 4. Signal readiness to the host — triggers the initial preferences
//    delivery via asyar:event:preferences:set-all.
window.parent.postMessage({ type: 'asyar:extension:loaded', extensionId }, '*');

// 5. Mount the detail view. Passing `context` lets children subscribe to
//    context.onPreferencesChanged and react to live preference edits
//    without reloading the iframe.
const app = mount(DetailView, {
  target: document.getElementById('app')!,
  props: {
    context,
    logger: context.getService<ILogService>('log'),
  },
});

export default app;
