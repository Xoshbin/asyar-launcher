// ──────────────────────────────────────────────────────────────────────
// index.ts — Extension class for a searchable extension.
//
// main.ts imports this class and registers it with ExtensionBridge via
// `bridge.registerExtensionImplementation(extensionId, extension)`. The
// bridge then dispatches `asyar:search:request` messages into
// `extension.search(query)` and `asyar:command:execute` into
// `extension.executeCommand(...)`.
//
// Preferences (declared in manifest.json) are reachable via
// `context.preferences.*` after `initialize()` is called by the bridge.
// The reference is captured here so search() can consult live values on
// every query.
// ──────────────────────────────────────────────────────────────────────

import type {
  Extension,
  ExtensionContext,
  ExtensionResult,
  IExtensionManager,
  ILogService,
} from "asyar-sdk";
import DetailView from "./DetailView.svelte";

// Sample data — replace with your own data source
const SAMPLE_ITEMS = [
  { id: "1", title: "First Item", subtitle: "A sample search result" },
  { id: "2", title: "Second Item", subtitle: "Another sample result" },
  { id: "3", title: "Third Item", subtitle: "One more example" },
];

class MyExtension implements Extension {
  private extensionManager?: IExtensionManager;
  private logger?: ILogService;
  private context?: ExtensionContext;

  async initialize(context: ExtensionContext): Promise<void> {
    this.context = context;
    this.extensionManager = context.getService<IExtensionManager>("ExtensionManager");
    this.logger = context.getService<ILogService>("LogService");
  }

  async activate(): Promise<void> {}
  async deactivate(): Promise<void> {}
  async viewActivated(_viewId: string): Promise<void> {}
  async viewDeactivated(_viewId: string): Promise<void> {}

  async search(query: string): Promise<ExtensionResult[]> {
    // Read the live preference on every call — users may edit `maxResults`
    // in Settings between invocations and we should honor the new value.
    const rawMax = this.context?.preferences.maxResults;
    const maxResults = typeof rawMax === "number" ? rawMax : 10;

    const q = query.toLowerCase();
    return SAMPLE_ITEMS
      .filter((item) => !q || item.title.toLowerCase().includes(q))
      .slice(0, maxResults)
      .map((item) => ({
        score: 1,
        title: item.title,
        subtitle: item.subtitle,
        type: "view" as const,
        viewPath: "{{EXTENSION_ID}}/DetailView",
        action: () => {
          this.extensionManager?.navigateToView("{{EXTENSION_ID}}/DetailView");
        },
      }));
  }

  async executeCommand(commandId: string, _args?: Record<string, any>): Promise<any> {
    if (commandId === "search") {
      return { type: "view", viewPath: "{{EXTENSION_ID}}/DetailView" };
    }
  }

  onUnload = () => {};
}

export default new MyExtension();
export { DetailView };
