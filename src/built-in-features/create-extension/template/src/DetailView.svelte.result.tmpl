    <h1>{selectedTitle}</h1>
    <p class="subtitle">{{EXTENSION_NAME}}</p>
  </div>

  <div class="content">
    <div class="placeholder">
      <asyar-icon name="info" size="24"></asyar-icon>
      <p>Replace this with your detail content.</p>
    </div>
  </div>
</div>

