{
  "id": "{{EXTENSION_ID}}",
  "name": "{{EXTENSION_NAME}}",
  "version": "1.0.0",
  "description": "{{EXTENSION_DESC}}",
  "author": "Developer",
  "searchable": true,
  "icon": "⚡",
  "type": "extension",
  "asyarSdk": "{{SDK_VERSION}}",
  "permissions": [
    "notifications:send"
  ],
  "preferences": [
    {
      "name": "notifyOnComplete",
      "type": "checkbox",
      "title": "Notify when action finishes",
      "description": "Show a system notification when a logic action completes.",
      "default": true
    }
  ],
  "commands": [
    {
      "id": "run",
      "name": "Run {{EXTENSION_NAME}}",
      "description": "{{EXTENSION_DESC}}",
      "mode": "background"
    }
  ],
  "background": {
    "main": "dist/worker.js"
  }
}
