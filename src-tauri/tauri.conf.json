{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "asyar",
  "identifier": "org.asyar.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "asyar",
        "width": 740,
        "height": 560,
        "fullscreen": false,
        "decorations": false,
        "alwaysOnTop": true,
        "transparent": true,
        "shadow": true,
        "center": true,
        "visible": false
      },
      {
        "label": "settings",
        "url": "/settings",
        "fullscreen": false,
        "resizable": true,
        "title": "Asyar Settings",
        "width": 1000,
        "height": 700,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' asyar-icon: http://asyar-icon.localhost asset: https://asset.localhost data: https://*; connect-src 'self' https://api.openai.com https://api.anthropic.com https://generativelanguage.googleapis.com https://openrouter.ai https://asyar.org http://localhost:* https://*; frame-src asyar-extension: http://asyar-extension.localhost blob:; font-src 'self'; object-src 'none'; base-uri 'self'",
      "capabilities": [
        "default"
      ]
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "built-in-features"
    ],
    "macOS": {
      "signingIdentity": "Developer ID Application: Khoshbin Ahmed (877MKJ6983)",
      "entitlements": "./entitlements.plist",
      "minimumSystemVersion": "13.0"
    }
  },
  "plugins": {
    "fs": {},
    "http": null,
    "updater": {
      "active": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEMyNDUwMkFDNTdBOUQxMjUKUldRbDBhbFhyQUpGd3ArcUplOWtFTk1UV1I1QWIweGtCRU0zMTd5YjZZTXdJbi95Zm43aExZZk0K",
      "endpoints": [
        "https://asyar.org/api/update/{{target}}/{{current_version}}"
      ]
    }
  }
}