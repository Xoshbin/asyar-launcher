{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "autostart:allow-enable",
    "autostart:allow-disable",
    "autostart:allow-is-enabled",
    "clipboard-manager:allow-read-text",
    "clipboard-manager:allow-write-text",
    "clipboard-manager:allow-read-image",
    "log:default",
    "notification:allow-notify",
    "notification:default",
    "opener:allow-open-url",
    "core:path:default",
    "core:path:allow-resolve-directory",
    {
      "identifier": "opener:allow-open-path",
      "allow": [
        { "path": "/Applications/*" },
        { "path": "/System/Applications/*" },
        { "path": "/System/Library/PreferencePanes/*" },
        { "path": "/System/Library/CoreServices/Applications/*" }
      ]
    },
    {
      "identifier": "fs:allow-exists",
      "allow": [
        { "path": "$APPDATA/extensions" },
        { "path": "$APPDATA/extensions/**" },
        { "path": "$APPDATA/extensions/**/.*" },
        { "path": "$APPDATA/asyar-api" },
        { "path": "$APPDATA/asyar-api/**" },
        { "path": "/Users/khoshbin/develop/asyar/asyar-api" }
      ]
    },
    {
      "identifier": "fs:allow-stat",
      "allow": [
        { "path": "$APPDATA/extensions" },
        { "path": "$APPDATA/extensions/**" },
        { "path": "$APPDATA/extensions/**/.*" }
      ]
    },
    {
      "identifier": "fs:allow-read-dir",
      "allow": [
        { "path": "$APP/src/built-in-extensions" },
        { "path": "$APP/src/built-in-extensions/**" },
        { "path": "$APPDATA/extensions" },
        { "path": "$APPDATA/extensions/**" },
        { "path": "$APPDATA/asyar-api" },
        { "path": "$APPDATA/asyar-api/**" }
      ]
    },
    {
      "identifier": "fs:allow-read-text-file",
      "allow": [
        { "path": "$APP/src/built-in-extensions/**" },
        { "path": "$APPDATA/extensions/**" },
        { "path": "$APPDATA/extensions/**/.*" },
        { "path": "$APPDATA/asyar-api/**" },
        { "path": "$APPDATA/asyar-api/**/.*" }
      ]
    },
    {
      "identifier": "fs:allow-read-file",
      "allow": [
        { "path": "$APP/src/built-in-extensions/**" },
        { "path": "$APPDATA/extensions/**" },
        { "path": "$APPDATA/extensions/**/.*" },
        { "path": "$APPDATA/asyar-api/**" },
        { "path": "$APPDATA/asyar-api/**/.*" }
      ]
    },
    {
      "identifier": "fs:allow-mkdir",
      "allow": [
        { "path": "$APPDATA/extensions" },
        { "path": "$APPDATA/extensions/**" },
        { "path": "$APPDATA/asyar-api" },
        { "path": "$APPDATA/asyar-api/**" }
      ]
    },
    {
      "identifier": "fs:allow-write-text-file",
      "allow": [
        { "path": "$APPDATA/extensions/**" },
        { "path": "$APPDATA/extensions/**/.*" },
        { "path": "$APPDATA/asyar-api/**" },
        { "path": "$APPDATA/asyar-api/**/.*" }
      ]
    },
    {
      "identifier": "fs:allow-write-file",
      "allow": [
        { "path": "$APPDATA/extensions/**" },
        { "path": "$APPDATA/extensions/**/.*" },
        { "path": "$APPDATA/asyar-api/**" },
        { "path": "$APPDATA/asyar-api/**/.*" }
      ]
    },
    {
      "identifier": "fs:allow-remove",
      "allow": [
        { "path": "$APPDATA/extensions/**" },
        { "path": "$APPDATA/extensions/**/.*" },
        { "path": "$APPDATA/asyar-api/**" },
        { "path": "$APPDATA/asyar-api/**/.*" }
      ]
    },
    "store:allow-set",
    "store:allow-get",
    "store:allow-save",
    "store:allow-delete",
    "store:default",
    "global-shortcut:allow-register",
    "global-shortcut:allow-is-registered",
    "global-shortcut:allow-unregister",
    "global-shortcut:allow-unregister-all",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        { "name": "git-clone", "cmd": "git", "args": [{ "validator": ".*" }, { "validator": ".*" }, { "validator": ".*" }, { "validator": ".*" }, { "validator": ".*" }] },
        { "name": "npm-install", "cmd": "npm", "args": ["install", { "validator": ".*" }] },
        { "name": "pnpm-add", "cmd": "pnpm", "args": ["add", { "validator": ".*" }, { "validator": ".*" }] },
        { "name": "pnpm-install", "cmd": "pnpm", "args": ["install", { "validator": ".*" }] },
        { "name": "pnpm-build", "cmd": "pnpm", "args": ["run", "build"] },
        { "name": "ln-s", "cmd": "ln", "args": ["-s", { "validator": ".*" }, { "validator": ".*" }] },
        { "name": "pnpm-generic", "cmd": "pnpm", "args": [{ "validator": ".*" }, { "validator": ".*" }, { "validator": ".*" }, { "validator": ".*" }] }
      ]
    }
  ]
}
